{
  "name": "si-lamin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "prisma:validate": "prisma validate",
    "prisma:status": "prisma migrate status",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "bun ./prisma/seed.ts",
    "prisma:seed:production": "NODE_ENV=production bun ./prisma/seed-production.ts",
    "prisma:seed:production:force": "NODE_ENV=production bun ./prisma/seed-production.ts --force",
    "prisma:reset": "prisma migrate reset --force",
    "migration:pre": "bash ./scripts/pre-migration.sh",
    "migration:apply": "bash ./scripts/apply-migration.sh",
    "migration:apply:seed": "bash ./scripts/apply-migration.sh --with-seed",
    "migration:apply:prod": "bash ./scripts/apply-migration.sh --production",
    "migration:apply:prod:seed": "bash ./scripts/apply-migration.sh --production --with-seed",
    "migration:rollback": "bash ./scripts/rollback-migration.sh",
    "migration:monitor": "bash ./scripts/monitor-migration.sh",
    "docker:build": "docker build -f Dockerfile.production -t driver-booking:latest .",
    "docker:build:tag": "docker build -f Dockerfile.production -t driver-booking:$(date +%Y%m%d_%H%M%S) .",
    "docker:compose:up": "docker-compose -f docker-compose.production.yml up -d",
    "docker:compose:down": "docker-compose -f docker-compose.production.yml down",
    "docker:compose:logs": "docker-compose -f docker-compose.production.yml logs -f",
    "docker:compose:ps": "docker-compose -f docker-compose.production.yml ps",
    "deploy:check": "bash ./scripts/pre-migration.sh",
    "deploy:production": "bash ./scripts/apply-migration.sh --production --with-seed",
    "production:start": "docker-compose -f docker-compose.production.yml up -d",
    "production:stop": "docker-compose -f docker-compose.production.yml down",
    "production:logs": "docker-compose -f docker-compose.production.yml logs -f app",
    "production:health": "curl http://localhost:3000/api/health",
    "production:monitor": "bash ./scripts/monitor-migration.sh"
  },
  "prisma": {
    "seed": "bun ./prisma/seed.ts"
  },
  "dependencies": {
